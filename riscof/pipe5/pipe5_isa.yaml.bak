# ============================================================
#  pipe5_isa.yaml  -  Specificatia ISA pentru DUT (RV32IMZicsr)
# ------------------------------------------------------------
#  Sablon de start. Valideaza-l cu riscv-config / riscof inainte de rulare.
#  Daca apar erori de schema, regenereaza scheletul cu:
#     riscof setup --dutname=pipe5 --refname=sail_cSim
#  si pastreaza din acesta doar sirul ISA si valorile reset.
#
#  NOTA: Zicsr e declarat fiindca mediul arch-test il cere. Nucleul curent
#  NU implementeaza inca CSR-urile/trap-urile -> de adaugat in faza urmatoare.
# ============================================================
hart_ids: [0]
hart0:
  ISA: RV32IMZicsr
  physical_addr_sz: 32
  User_Spec_Version: '2.3'
  supported_xlen: [32]
  misa:
    reset-val: 0x40001100
    rv32:
      accessible: true
      mxl:
        implemented: true
        type:
          warl:
            dependency_fields: []
            legal: ["mxl[1:0] in [0x1]"]
            wr_illegal: ["Unchanged"]
      extensions:
        implemented: true
        type:
          warl:
            dependency_fields: []
            legal: ["extensions[25:0] bitmask [0x0001100, 0x0000000]"]
            wr_illegal: ["Unchanged"]
  mvendorid:
    reset-val: 0x0
  marchid:
    reset-val: 0x0
  mimpid:
    reset-val: 0x0
  mhartid:
    reset-val: 0x0
